---
layout: null
---
[
  {% assign all = "" | split: "" %}
  {% assign all = all | concat: site.posts %}
  {% assign all = all | concat: site.projects %}
  {% for item in all %}
  {
    "title":   {{ item.title | jsonify }},
    "url":     {{ item.url   | relative_url | jsonify }},
    "type":    {% if item.collection == "projects" %}"Project"{% else %}"Post"{% endif %},
    "tags":    {{ item.tags  | default: "" | jsonify }},
    "content": {{ item.content | strip_html | truncatewords: 60 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
